# WorldSignal environment configuration.
# Copy to backend/.env.local (git-ignored) for local development; dev.sh loads it.
# In production, set these as real environment variables / secrets.

# --- Required ---
# Postgres connection string. Matches docker-compose's default credentials.
DATABASE_URL="postgresql://worldsignal:worldsignal@localhost:5432/worldsignal?sslmode=disable"

# --- Process role: all | api | worker (default: all) ---
ROLE="all"

# --- HTTP server ---
HOST="0.0.0.0"
PORT="4000"

# --- LLM enrichment (optional) ---
# Empty key => deterministic heuristic enrichment (the pipeline still works).
# Admins can also add keys at runtime via Settings; those override this one.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Secrets ---
# Signs delivery webhooks AND derives the AES key that encrypts admin LLM keys
# and email-connector secrets at rest. Use a strong, stable value in production
# (rotating it invalidates stored LLM keys and email connector passwords).
WEBHOOK_SIGNING_SECRET="change-me-in-prod"

# --- Email delivery (optional) ---
# Email connectors (SMTP) are configured in the console under Connectors and are
# encrypted at rest — no SMTP credentials live here. APP_BASE_URL is the public
# console URL; when set, signal/digest emails link back to the signal detail page.
APP_BASE_URL=""
# How often the digest scheduler checks for due email digests (seconds).
DIGEST_TICK_SECONDS="60"

# --- Default admin (seeded on first boot when no users exist) ---
ADMIN_EMAIL="admin@worldsignal.local"
ADMIN_PASSWORD="admin12345"          # change after first login

# --- Scheduler & source failure handling ---
SCHEDULER_TICK_MS="30000"            # how often the scheduler enqueues due sources
SOURCE_FAILURE_THRESHOLD="5"         # consecutive failures before cooldown
SOURCE_COOLDOWN_MINUTES="180"        # cooldown duration; auto-retried after

# Postgres (the ONLY datastore — jobs run on pg-boss inside this same database)
DATABASE_URL="postgresql://worldsignal:worldsignal@localhost:5432/worldsignal?schema=public"

# HTTP server
PORT=4000
HOST=0.0.0.0

# OpenAI — optional. If unset, enrichment uses a deterministic heuristic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Process role: "all" (default) runs API + workers + scheduler in one process.
# Use "api" or "worker" to split them in production.
ROLE=all

# Webhook signing secret (HMAC-SHA256 over the payload)
WEBHOOK_SIGNING_SECRET=change-me-in-prod
